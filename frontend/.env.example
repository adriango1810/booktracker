# Variables de entorno para el escáner de ISBN
# Copiar a .env y ajustar según sea necesario

# Opcional: ratio del ROI (0–1), ej. 0.65
# VITE_SCAN_ROI_RATIO=0.65

# Opcional: lado largo mínimo del bitmap enviado a ZXing (px)
# VITE_SCAN_DECODE_MIN_LONG_EDGE=1024

# FPS por dispositivo (si se quiere sobreescribir los defaults)
# VITE_SCAN_FPS_IOS=2
# VITE_SCAN_FPS_ANDROID=4

# URL del backend para identificación de libros
# VITE_API_BASE_URL=https://tu-backend.example.com

# Configuración de comportamiento
# VITE_AUTO_OPEN=true
